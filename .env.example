# ─── Required ────────────────────────────────────────────────────────────────
# Your Google Calendar ID. Find it in Google Calendar → Settings → your calendar
# → "Calendar ID" (e.g. abc123@group.calendar.google.com, or "primary")
# The calendar must be shared with: moving-tracker-server@ad-report-automation-484101.iam.gserviceaccount.com
CALENDAR_ID=primary

# ─── Optional: Capacity ──────────────────────────────────────────────────────
# Maximum number of jobs allowed per day (default: 3)
MAX_JOBS_PER_DAY=3

# ─── Optional: Service account (for Vercel deployment) ───────────────────────
# Paste the full service_account.json contents as a single-line JSON string.
# If not set, the API reads from ./service_account.json (works for local dev).
# GOOGLE_SERVICE_ACCOUNT={"type":"service_account","project_id":"..."}

# ─── Optional: Address autocomplete ─────────────────────────────────────────
# Add your Google Maps API key, then uncomment the <script> tag in index.html
# GOOGLE_MAPS_API_KEY=AIza...

# ─── Optional: GoHighLevel CRM sync ─────────────────────────────────────────
# When set, every confirmed booking also creates/updates a contact in GHL
# GHL_ACCESS_TOKEN=eyJ...
# GHL_LOCATION_ID=abc123
